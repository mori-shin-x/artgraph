{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm oxfmt --write src/ tests/ 2>&1; pnpm oxlint src/ tests/ 2>&1; pnpm tsgo --noEmit 2>&1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/stop-hook.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
