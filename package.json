{
  "name": "artgraph",
  "version": "0.1.0",
  "description": "Typed artifact graph for TS/JS — trace specs, docs, code, and tests bidirectionally",
  "type": "module",
  "bin": {
    "artgraph": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "artgraph": "node --enable-source-maps ./dist/cli.js",
    "test": "vitest run && vitest run --config vitest.perf.config.ts",
    "test:unit": "vitest run",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:watch": "vitest",
    "knip": "knip",
    "prepublishOnly": "pnpm test && rm -rf dist && tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShintaroMorimoto/artgraph.git"
  },
  "bugs": {
    "url": "https://github.com/ShintaroMorimoto/artgraph/issues"
  },
  "homepage": "https://github.com/ShintaroMorimoto/artgraph#readme",
  "keywords": [
    "traceability",
    "spec-driven-development",
    "impact-analysis",
    "spec-kit",
    "kiro",
    "requirements",
    "drift-detection",
    "monorepo",
    "typescript",
    "cli"
  ],
  "author": "Shintaro Morimoto",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "glob": "^11.0.2",
    "mdast-util-to-string": "^4.0.0",
    "remark-parse": "^11.0.0",
    "ts-morph": "^25.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "knip": "^6.17.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.8.0"
}
