{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "indentStyle": "space",
  "indentWidth": 2,
  "printWidth": 100,
  "ignorePatterns": [
    "dist/",
    "templates/graph/vendor/",
    "**/*.md",
    "**/*.json",
    "**/*.jsonc",
    "**/*.yml",
    "**/*.yaml",
    "**/*.html",
    "**/*.css"
  ]
}
